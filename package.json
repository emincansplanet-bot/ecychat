{
  "name": "ecychat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "prisma generate && node scripts/dev-with-db.mjs",
    "demo": "node scripts/ensure-demo-env.cjs && node scripts/ensure-db-local.cjs && prisma generate && prisma migrate deploy && npm run db:seed && node scripts/run-next-dev.mjs",
    "build": "prisma generate && next build",
    "start": "prisma generate && next start -p 3000 -H 127.0.0.1",
    "start:live": "prisma generate && prisma migrate deploy && next start -p 3000 -H 127.0.0.1",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "docker:db": "docker compose up -d --wait",
    "bootstrap:db": "node scripts/bootstrap-local-db.mjs",
    "setup:local": "node scripts/bootstrap-local-db.mjs && prisma generate && prisma migrate deploy && npm run db:seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "ioredis": "^5.10.1",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "pg": "^8.14.1"
  }
}
