# Kopyala: cp .env.example .env
# Yerel DB: docker compose up -d  (ecychat/docker-compose.yml)
# veya Mac’e kurulu Postgres: .env’e ECYCHAT_SKIP_DOCKER=1 + bir kez:
#   BOOTSTRAP_DATABASE_URL=postgresql://SÜPERKULLANICI:SIFRE@127.0.0.1:5432/postgres
#   npm run setup:local
# (Bootstrap sonrası BOOTSTRAP satırını silin; şifrede ! → %21)

# Panel tek adres (npm run dev / demo hep 3000; başka port: ECYCHAT_DEV_PORT=4000 npm run dev)
# ECYCHAT_SKIP_DOCKER=1
PORT=3000
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL (LIVE / yerel Docker varsayılanı)
DATABASE_URL="postgresql://ecychat:ecychat@127.0.0.1:5432/ecychat?schema=public"

AUTH_SECRET=üret-openssl-rand-base64-32-ile

WHATSAPP_VERIFY_TOKEN=demo-verify

SEED_ADMIN_PASSWORD=changeme123

SEED_META_PHONE_NUMBER_ID=

WHATSAPP_APP_SECRET=

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v22.0

# Konuşma ekranında şablon formu için varsayılanlar (opsiyonel)
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=tr

# Yerel tam akış: Meta olmadan giden mesaj (DB’ye yazar). Canlıda false yapın.
DEMO_MOCK_SEND=true

# İsteğe bağlı: çoklu Node / yatay ölçekte gelen kutusu SSE — docker-compose’daki redis için:
# REDIS_URL=redis://127.0.0.1:6379
