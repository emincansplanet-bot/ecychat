# Kopyala: cp .env.example .env
#
# PostgreSQL için harici siteye üyelik gerekmez: prod’da DB, VPS’teki Docker
# “db” konteynerindedir (docker-compose.prod.yml). Neon/RDS istemiyorsan ek hesap yok.

# -----------------------------------------------------------------------------
# Yerel geliştirme (docker-compose.yml / npm run dev)
# -----------------------------------------------------------------------------
# ECYCHAT_SKIP_DOCKER=1
PORT=3000
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

DATABASE_URL="postgresql://ecychat:ecychat@127.0.0.1:5432/ecychat?schema=public"

# -----------------------------------------------------------------------------
# Üretim (docker-compose.prod.yml — .env’de mutlaka doldur)
# -----------------------------------------------------------------------------
# Güçlü şifre +:  openssl rand -base64 32
POSTGRES_PASSWORD=buraya-guclu-db-sifresi
AUTH_SECRET=buraya-openssl-rand-base64-32

# Üretimde üçü de gerçek panel adresi: http://SUNUCU_IP:3000 veya https://alanadin.com
# AUTH_URL=...
# NEXTAUTH_URL=...
# NEXT_PUBLIC_APP_URL=...
# docker-compose.prod.yml içinde AUTH_TRUST_HOST=true (nginx arkasında CSRF için)

DEMO_MOCK_SEND=false

# true iken giriş atlanır, ilk yönetici olarak panel açılır (internet-facing üretimde KAPALI tut).
# ECYCHAT_OPEN_PANEL=false

# Varsayılan yeterli (compose): redis://redis:6379
# REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# İlk admin / seed (çoğunlukla yerel; prod’da ihtiyaca göre)
# -----------------------------------------------------------------------------
# Örnek rastgele kimlikler — kopyaladıktan sonra üretimde mutlaka kendi değerlerinle değiştir.
# Bu alanları .env’den silersen seed yine admin@ecychat.local / operator@ecychat.local kullanır.
SEED_ADMIN_EMAIL=admin-817e42ad@ecychat.local
SEED_OPERATOR_EMAIL=operator-db6a5e1a@ecychat.local
SEED_ADMIN_PASSWORD=YvTWS1e7mapo0CEbBLzk
SEED_META_PHONE_NUMBER_ID=

# -----------------------------------------------------------------------------
# Meta WhatsApp Cloud API (opsiyonel; canlı webhook için doldur)
# -----------------------------------------------------------------------------
WHATSAPP_VERIFY_TOKEN=demo-verify
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v22.0
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=tr
